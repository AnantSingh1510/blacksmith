{
  "name": "@blacksmith/health",
  "version": "0.1.0",
  "description": "Health, readiness, and liveness endpoints for Blacksmith.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "clean": "rm -rf dist",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run src --passWithNoTests"
  },
  "dependencies": {
    "@blacksmith/core": "0.1.0"
  },
  "devDependencies": {
    "typescript": "^5.7.3",
    "vitest": "^4.1.8"
  }
}
