{
  "name": "@blacksmith/adapters",
  "version": "0.1.0",
  "description": "HTTP framework adapters for Blacksmith.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./express": {
      "types": "./dist/express.d.ts",
      "import": "./dist/express.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "clean": "rm -rf dist",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run src --passWithNoTests"
  },
  "devDependencies": {
    "@types/express": "^5.0.0",
    "typescript": "^5.7.3",
    "vitest": "^4.1.8"
  }
}
